#!/bin/bash
# Remove the macOS LaunchAgent that starts the local knowledge-base backend at login.

set -euo pipefail

LABEL="com.memai.knowledge-base"
PLIST_PATH="$HOME/Library/LaunchAgents/$LABEL.plist"
USER_DOMAIN="gui/$(id -u)"

if [ "$(uname -s)" != "Darwin" ]; then
  echo "✗ 当前自动启动脚本只支持 macOS。"
  exit 1
fi

launchctl bootout "$USER_DOMAIN" "$PLIST_PATH" >/dev/null 2>&1 \
  || launchctl unload "$PLIST_PATH" >/dev/null 2>&1 \
  || true

if [ -f "$PLIST_PATH" ]; then
  rm "$PLIST_PATH"
  echo "✓ 已取消开机自动启动：$PLIST_PATH"
else
  echo "○ 未找到开机启动配置：$PLIST_PATH"
fi

echo "  这只会移除登录启动项，不会杀掉当前已经运行的后端进程。"
