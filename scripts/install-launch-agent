#!/bin/bash
# Install a macOS LaunchAgent that starts the local knowledge-base backend at login.

set -euo pipefail

LABEL="com.memai.knowledge-base"
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG_FILE="$HOME/.kb_config"
PLIST_DIR="$HOME/Library/LaunchAgents"
PLIST_PATH="${MEMAI_LAUNCH_AGENT_PLIST_PATH:-$PLIST_DIR/$LABEL.plist}"
USER_DOMAIN="gui/$(id -u)"
DRY_RUN=false

if [ "${1:-}" = "--dry-run" ]; then
  DRY_RUN=true
fi

if [ "$(uname -s)" != "Darwin" ]; then
  echo "✗ 当前自动启动脚本只支持 macOS。"
  exit 1
fi

if [ ! -f "$REPO_DIR/start.sh" ]; then
  echo "✗ 未找到 $REPO_DIR/start.sh"
  exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
  echo "✗ 未找到配置文件 $CONFIG_FILE"
  echo "  请先运行：bash $REPO_DIR/onboard.sh"
  exit 1
fi

set -a
# shellcheck source=/dev/null
source "$CONFIG_FILE"
set +a

DATA_DIR="${KB_DATA_DIR:-$HOME/.knowledge-base-extension}"
LOG_DIR="$DATA_DIR/.logs"
PATH_VALUE="$HOME/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

xml_escape() {
  printf '%s' "$1" \
    | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g'
}

mkdir -p "$PLIST_DIR" "$LOG_DIR"

cat > "$PLIST_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$(xml_escape "$REPO_DIR/start.sh")</string>
  </array>

  <key>WorkingDirectory</key>
  <string>$(xml_escape "$REPO_DIR")</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <false/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$(xml_escape "$HOME")</string>
    <key>PATH</key>
    <string>$(xml_escape "$PATH_VALUE")</string>
  </dict>

  <key>StandardOutPath</key>
  <string>$(xml_escape "$LOG_DIR/launch-agent.out.log")</string>

  <key>StandardErrorPath</key>
  <string>$(xml_escape "$LOG_DIR/launch-agent.err.log")</string>
</dict>
</plist>
EOF

plutil -lint "$PLIST_PATH" >/dev/null

if [ "$DRY_RUN" = true ]; then
  echo "✓ plist 已生成并通过校验：$PLIST_PATH"
  echo "  dry-run 模式未加载 LaunchAgent。"
  exit 0
fi

launchctl bootout "$USER_DOMAIN" "$PLIST_PATH" >/dev/null 2>&1 \
  || launchctl unload "$PLIST_PATH" >/dev/null 2>&1 \
  || true

if ! launchctl bootstrap "$USER_DOMAIN" "$PLIST_PATH" >/dev/null 2>&1; then
  launchctl load "$PLIST_PATH"
fi

launchctl kickstart -k "$USER_DOMAIN/$LABEL" >/dev/null 2>&1 || true

echo "✓ 已安装开机自动启动：$PLIST_PATH"
echo "  登录 macOS 后会自动运行：bash $REPO_DIR/start.sh"
echo "  日志：$LOG_DIR/launch-agent.out.log"
echo "  一般不需要再运行其他命令；如果要排查，可运行：$REPO_DIR/scripts/launch-agent-status"
echo "  如果要取消开机启动，可运行：$REPO_DIR/scripts/uninstall-launch-agent"
